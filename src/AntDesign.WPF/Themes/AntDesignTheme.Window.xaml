<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:controls="clr-namespace:AntDesign.WPF.Controls"
    xmlns:helpers="clr-namespace:AntDesign.WPF.Helpers">

    <!--
        Ant Design WPF — Window Style
        Named style "AntDesignWindow":
          - Background : Bg.Layout
          - Foreground : Text
          - FontFamily : Segoe UI
          - FontSize   : 14 (AntDesign.FontSize token)
        Usage: <Window Style="{StaticResource AntDesignWindow}" ...>
    -->

    <Style x:Key="AntDesignWindow" TargetType="{x:Type Window}">
        <Setter Property="Background"      Value="{DynamicResource AntDesign.Brush.Bg.Layout}" />
        <Setter Property="Foreground"      Value="{DynamicResource AntDesign.Brush.Text}" />
        <Setter Property="FontFamily"      Value="Segoe UI" />
        <Setter Property="FontSize"        Value="{DynamicResource AntDesign.FontSize}" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode"  Value="Auto" />
    </Style>

    <!-- ================================================================
         CAPTION BUTTON STYLES
         ================================================================ -->

    <!-- Base caption button style: 46x32, transparent, hover/pressed feedback -->
    <Style x:Key="AntDesign.WindowCaptionButton" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AntDesign.Brush.Text.Secondary}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource AntDesign.Brush.Fill.Tertiary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource AntDesign.Brush.Fill.Secondary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close button: red hover with white icon -->
    <Style x:Key="AntDesign.WindowCloseButton" TargetType="{x:Type Button}"
           BasedOn="{StaticResource AntDesign.WindowCaptionButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bg"
                            Background="Transparent"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                        <Path x:Name="CloseIcon"
                              Data="M 0,0 L 10,10 M 10,0 L 0,10"
                              Stroke="{DynamicResource AntDesign.Brush.Text.Secondary}"
                              StrokeThickness="1"
                              Width="10" Height="10"
                              Stretch="None"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#E81123" />
                            <Setter TargetName="CloseIcon" Property="Stroke" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#C50F1F" />
                            <Setter TargetName="CloseIcon" Property="Stroke" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================
         BORDERLESS WINDOW STYLE
         ================================================================ -->

    <Style x:Key="AntDesignWindow.Borderless" TargetType="{x:Type Window}"
           BasedOn="{StaticResource AntDesignWindow}">
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="helpers:BorderlessWindowBehavior.Enable" Value="True" />
        <Setter Property="shell:WindowChrome.WindowChrome">
            <Setter.Value>
                <shell:WindowChrome
                    CaptionHeight="48"
                    GlassFrameThickness="0,0,0,1"
                    ResizeBorderThickness="4"
                    UseAeroCaptionButtons="False"
                    CornerRadius="0" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Window}">
                    <Border x:Name="WindowBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource AntDesign.Brush.Border.Secondary}"
                            BorderThickness="1">
                        <Grid>
                            <!-- Full-area content (Demo fills entire window) -->
                            <AdornerDecorator>
                                <ContentPresenter />
                            </AdornerDecorator>

                            <!-- Title bar overlaid at top -->
                            <Border x:Name="TitleBar"
                                    Height="48"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource AntDesign.Brush.Bg.Container}"
                                    BorderBrush="{DynamicResource AntDesign.Brush.Border.Secondary}"
                                    BorderThickness="0,0,0,1">
                                <DockPanel LastChildFill="True">
                                    <!-- Caption buttons (right-docked) -->
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Stretch">
                                        <!-- Minimize -->
                                        <Button x:Name="PART_MinimizeButton"
                                                Style="{StaticResource AntDesign.WindowCaptionButton}"
                                                AutomationProperties.Name="Minimize">
                                            <Path Data="M 0,5 H 10"
                                                  Stroke="{DynamicResource AntDesign.Brush.Text.Secondary}"
                                                  StrokeThickness="1"
                                                  Width="10" Height="10"
                                                  Stretch="None"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Button>
                                        <!-- Maximize / Restore -->
                                        <Button x:Name="PART_MaximizeButton"
                                                Style="{StaticResource AntDesign.WindowCaptionButton}"
                                                AutomationProperties.Name="Maximize">
                                            <Grid Width="10" Height="10">
                                                <Path x:Name="MaximizeIcon"
                                                      Data="M 0,0 H 10 V 10 H 0 Z"
                                                      Stroke="{DynamicResource AntDesign.Brush.Text.Secondary}"
                                                      StrokeThickness="1"
                                                      Width="10" Height="10"
                                                      Stretch="None"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                                <Path x:Name="RestoreIcon"
                                                      Data="M 0,2 H 8 V 10 H 0 Z M 2,2 V 0 H 10 V 8 H 8"
                                                      Stroke="{DynamicResource AntDesign.Brush.Text.Secondary}"
                                                      StrokeThickness="1"
                                                      Width="10" Height="10"
                                                      Stretch="None"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Visibility="Collapsed" />
                                            </Grid>
                                        </Button>
                                        <!-- Close -->
                                        <Button x:Name="PART_CloseButton"
                                                Style="{StaticResource AntDesign.WindowCloseButton}"
                                                AutomationProperties.Name="Close" />
                                    </StackPanel>

                                    <!-- Title bar content (fills remaining space) -->
                                    <ContentPresenter Content="{Binding Path=(controls:WindowHelper.TitleBarContent), RelativeSource={RelativeSource TemplatedParent}}" />
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- When maximized: add padding to account for the window shadow area -->
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="WindowBorder" Property="Padding" Value="7" />
                            <Setter TargetName="WindowBorder" Property="BorderThickness" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
