## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]uild/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
artifacts/

# NuGet Packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
!**/[Pp]ackages/*.props
!**/[Pp]ackages/*.targets

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# xUnit
TestResults/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# Chutzpah Test Files
_Chutzpah*

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# StyleCop
StyleCopReport.xml

